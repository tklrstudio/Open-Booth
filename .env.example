# Open Booth — Server Configuration
# These values can also be passed as command-line arguments to server.py.
# CLI args take precedence over environment variables.

# Port the chunk server listens on (default: 8080)
# OB_PORT=8080

# Directory where uploaded chunks are stored (default: ./chunks)
# OB_CHUNKS_DIR=./chunks

# Maximum chunk size in MB (default: 200)
# OB_MAX_CHUNK_MB=200
